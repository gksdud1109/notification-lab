{
  "uid": "m0-fanout",
  "title": "동기 팬아웃 성능 분석",
  "tags": ["notification-lab", "m0"],
  "timezone": "browser",
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "POST /events 응답시간 (가설의 최종 증상)",
      "description": "동기 팬아웃이 요청 응답을 끌면 여기가 먼저 오른다. SLO 선(p99)과 비교하라.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by(le) (rate(http_server_requests_seconds_bucket{uri=\"/events\"}[1m])))",
          "legendFormat": "p95"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum by(le) (rate(http_server_requests_seconds_bucket{uri=\"/events\"}[1m])))",
          "legendFormat": "p99"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum by(le) (rate(http_server_requests_seconds_bucket{uri=\"/events\"}[1m])))",
          "legendFormat": "p50"
        }
      ]
    },
    {
      "id": 2,
      "title": "에러율 (가설 (d): 스레드풀 소진 → 실패)",
      "description": "5xx / 전체. 이게 오르기 시작한 시점 = 무너진 시점.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1 }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "(sum(rate(http_server_requests_seconds_count{uri=\"/events\",status=~\"5..\"}[1m])) or vector(0)) / sum(rate(http_server_requests_seconds_count{uri=\"/events\"}[1m]))",
          "legendFormat": "error rate"
        }
      ]
    },
    {
      "id": 3,
      "title": "팬아웃 1건 처리시간 (가설 (a): 순차 send 비용)",
      "description": "notiflab_fanout_duration — recipient 수와 같이 오르는지 보라.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "notiflab_fanout_duration_seconds{quantile=\"0.5\"}",
          "legendFormat": "p50"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "notiflab_fanout_duration_seconds{quantile=\"0.99\"}",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 4,
      "title": "Tomcat busy threads (가설 (c): 풀 소진)",
      "description": "max 200(기준선 고정)에 닿으면 신규 요청이 대기/실패한다.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {},
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 200 }] }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "tomcat_threads_busy_threads",
          "legendFormat": "busy"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "tomcat_threads_config_max_threads",
          "legendFormat": "max"
        }
      ]
    },
    {
      "id": 5,
      "title": "부하 수준 (활성 WS 세션 / 이벤트 처리율)",
      "description": "k6가 건 부하가 실제로 걸렸는지 확인. 두 축(동접·rate)의 현재값.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "notiflab_sessions_active",
          "legendFormat": "ws sessions"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_server_requests_seconds_count{uri=\"/events\"}[1m]))",
          "legendFormat": "events/s"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
